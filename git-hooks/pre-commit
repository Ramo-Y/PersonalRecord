#!/bin/bash

# The Syncfusion license will only be updated from the GitHub Action and must not be checked in with the actual value
PROTECTED_FILE="src/PersonalRecord.App/SyncfusionLicense.txt"

if git diff --cached --name-only | grep -q "$PROTECTED_FILE"; then
    echo "WARNING: The file $PROTECTED_FILE contains the private Syncfusion license key."
    echo "This key must NOT be updated in this open-source project."
    echo "Please remove any changes to this file before committing."
    exit 1
fi

# SyncfusionVersion license key reminder
BUILD_PROPS_FILE="src/Directory.Build.props"

if git diff --cached --name-only | grep -q "$BUILD_PROPS_FILE"; then
    if git diff --cached "$BUILD_PROPS_FILE" | grep -E "\+.*<SyncfusionVersion>.*</SyncfusionVersion>"; then
        echo "WARNING: The SyncfusionVersion in $BUILD_PROPS_FILE has been updated."
        echo "If a new major version of Syncfusion is being used, ensure the Syncfusion license key is updated in the GitHub Action."
    fi
fi

exit 0
